# BlueLotus V2 macOS environment template
# Copy to ~/bluelotus2/.env and fill privately.
# Never share a completed .env file.

BLUELOTUS_ROOT=$HOME/bluelotus2

# MySQL 8.4.9 LTS
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=bluelotus3
MYSQL_USER=bluelotus_app
MYSQL_PASSWORD=CHANGE_ME

# Backward-compatible DB aliases used by helper scripts.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bluelotus3
DB_USER=bluelotus_app
DB_PASSWORD=CHANGE_ME

# Moomoo OpenD, read-only extraction protocol.
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# Optional external APIs.
FINNHUB_API_KEY=
FRED_API_KEY=
EIA_API_KEY=
BEA_API_KEY=
BLS_API_KEY=
USDA_FAS_API_KEY=
NEWS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Optional publishing / repository integrations.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GITHUB_USERNAME=
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# Runtime controls.
AGENT_VERSION=bluelotus_v2_macos_collector
RUN_EVERY_MINUTES=60
BLUELOTUS_TICKER_LIMIT=200
BL_RAW_SIGNALS_PER_SOURCE=10
BL_RAW_LATEST_LIMIT=200

